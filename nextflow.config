// bagASM Nextflow DSL2 pipeline configuration

nextflow.enable.dsl = 2

manifest {
    nextflowVersion = '!>=25.04.6,<26'
}

params {
    help    = false

    // ── Inputs ───────────────────────────────────────────────────────────────
    // Either r1/r2 (short-read assembly), or lr/lr_type (long-read assembly
    // via Flye), or both (long-read assembly + short-read polishing).
    r1       = null
    r2       = null
    lr       = null
    lr_type  = null   // ont | pacbio-clr | pacbio-hifi
    strain   = null
    outdir   = null

    // ── Resources ────────────────────────────────────────────────────────────
    threads     = 20
    max_memory  = null   // override if Docker memory < physical RAM (e.g. '50GB')

    // ── GetOrganelle ─────────────────────────────────────────────────────────
    // Organelle type passed to get_organelle_from_assembly.py/_from_reads.py
    // -F and get_organelle_config.py -a. One of: embplant_pt, embplant_mt,
    // embplant_nr, fungus_mt, fungus_nr, animal_mt, other_pt — or several
    // joined by comma, e.g. embplant_pt,embplant_mt (see --help).
    species = 'fungus_mt'
    // Downloaded once per --species via `get_organelle_config.py -a` and
    // cached here permanently (Nextflow storeDir) — not re-downloaded on
    // later runs requesting the same --species.
    getorganelle_db = "${projectDir}/assets/getorganelle_db"

    // ── chlomito (short-read path only) ───────────────────────────────────────
    // Start permissive and re-tune from the scatter plot chlomito writes out,
    // per the tool's own recommendation.
    chlomito_mito_alcr_cutoff = 0.1
    chlomito_mito_sdr_cutoff  = 0.1

    // ── Flye (long-read mode only) ──────────────────────────────────────────────
    ont_mode = 'hq'   // hq (--nano-hq, modern/Dorado-Guppy-sup) | raw (--nano-raw, R9/low-quality); --lr_type ont only
    flye_genome_size   = null   // e.g. '35m'; passed to Flye -g/--genome-size
    flye_asm_coverage  = null   // int; passed to Flye --asm-coverage (requires flye_genome_size)

    // ── medaka (--lr_type ont only) ────────────────────────────────────────────
    medaka_model = null   // null = auto-detect from basecalls

    // ── Polypolish ───────────────────────────────────────────────────────────
    polish_rounds = 3   // number of minibwa+polypolish iterations

    // ── Output ───────────────────────────────────────────────────────────────
    tracedir = "${params.outdir}/pipeline_info"
}

process {
    withLabel: 'process_low' {
        cpus   = { Math.min(4, Math.min(params.threads as int, Runtime.getRuntime().availableProcessors())) }
        memory = '8.GB'
    }
    withLabel: 'process_medium' {
        cpus   = { Math.min(8, Math.min(params.threads as int, Runtime.getRuntime().availableProcessors())) }
        memory = '16.GB'
    }
    withLabel: 'process_high' {
        cpus   = { Math.min(params.threads as int, Runtime.getRuntime().availableProcessors()) }
        memory = {
            params.max_memory
                ? nextflow.util.MemoryUnit.of(params.max_memory as String)
                : new nextflow.util.MemoryUnit(com.sun.management.OperatingSystemMXBean.class
                    .cast(java.lang.management.ManagementFactory.getOperatingSystemMXBean())
                    .getTotalPhysicalMemorySize()) - 4.GB
        }
    }
}

// ── Container settings ───────────────────────────────────────────────────────
docker {
    enabled    = true
    runOptions = '-u $(id -u):$(id -g)'
}

// ── Execution profiles ───────────────────────────────────────────────────────
profiles {
    standard {
        process.executor = 'local'
    }
    slurm {
        process.executor = 'slurm'
    }
    sge {
        process.executor = 'sge'
    }
}

// ── Tracing / reporting ──────────────────────────────────────────────────────
timeline {
    enabled   = true
    overwrite = true
    file      = "${params.tracedir}/execution_timeline.html"
}
report {
    enabled   = true
    overwrite = true
    file      = "${params.tracedir}/execution_report.html"
}
trace {
    enabled   = true
    overwrite = true
    file      = "${params.tracedir}/execution_trace.txt"
}
dag {
    enabled   = true
    overwrite = true
    file      = "${params.tracedir}/pipeline_dag.svg"
}
